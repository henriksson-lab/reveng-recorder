import { LineEdit, Button, CheckBox, ListView, VerticalBox, HorizontalBox } from "std-widgets.slint";

// One selectable device row in the picker.
struct DevItem {
    label: string,
}

// Shown when `record` is launched with no device specified: pick USB + PCIe capture targets.
export component DevicePicker inherits Window {
    title: "reveng-rec — select devices";
    preferred-width: 580px;
    preferred-height: 460px;
    min-width: 420px;
    min-height: 320px;

    in property <[DevItem]> usb_devices;
    in property <[DevItem]> pci_devices;
    in property <string> usb_note; // e.g. "USBPcap not installed — …" (shown when set)
    in property <string> pci_note; // e.g. "reveng-pcidrv not loaded — …" (shown when set)
    // (index, checked) reported to Rust as the user ticks boxes.
    callback usb_toggled(int, bool);
    callback pci_toggled(int, bool);
    callback start();

    VerticalBox {
        padding: 10px;
        spacing: 6px;

        Text { text: "Select devices to capture"; font-weight: 700; font-size: 15px; }
        Text {
            text: "Recording keyboard, mouse, screen + the selected device traffic on this machine. Leave all unchecked to record input + notes only.";
            wrap: word-wrap;
            font-size: 11px;
            color: #999999;
        }

        Text { text: "USB"; font-weight: 700; color: #6a9bd0; }
        Text {
            visible: root.usb_note != "";
            text: root.usb_note;
            wrap: word-wrap;
            font-size: 11px;
            color: #e0a020;
        }
        Rectangle {
            vertical-stretch: 1;
            background: #00000014;
            border-radius: 4px;
            ListView {
                for it[idx] in root.usb_devices: CheckBox {
                    text: it.label;
                    toggled => {
                        root.usb_toggled(idx, self.checked);
                    }
                }
            }
        }

        Text { text: "PCIe (one device co-logged)"; font-weight: 700; color: #b58cd0; }
        Text {
            visible: root.pci_note != "";
            text: root.pci_note;
            wrap: word-wrap;
            font-size: 11px;
            color: #e0a020;
        }
        Rectangle {
            vertical-stretch: 1;
            background: #00000014;
            border-radius: 4px;
            ListView {
                for it[idx] in root.pci_devices: CheckBox {
                    text: it.label;
                    toggled => {
                        root.pci_toggled(idx, self.checked);
                    }
                }
            }
        }

        HorizontalBox {
            alignment: end;
            Button {
                text: "Start recording";
                clicked => {
                    root.start();
                }
            }
        }
    }
}

// One entered note: elapsed time (mm:ss), the text, and where in the stream it landed
// (e.g. "usb 8.9k · pcie 900k"). Filled from Rust.
struct NoteRow {
    time: string,
    text: string,
    pos: string,
}

// The live "recording" window: a red REC indicator + elapsed clock + session size, a
// per-source rate/volume dashboard (essential once PCIe is firehosing), a scrollback log of
// notes already entered, and an input box that stamps a note onto the capture on Enter.
export component RecordWindow inherits Window {
    title: "reveng-rec — recording";
    preferred-width: 520px;
    preferred-height: 440px;
    min-width: 380px;
    min-height: 280px;

    in property <string> elapsed: "00:00";
    in property <string> status: "RECORDING";
    in property <bool> recording: true;
    in property <[NoteRow]> notes;

    // Live capture-health dashboard (sampled by a Rust timer).
    in property <string> size_text: "0 B";
    in property <bool> size_warn: false;
    in property <bool> usb_active: false;
    in property <string> usb_stats: "";
    in property <string> usb_endpoints: ""; // top endpoints by volume ("0x81 iso 1.2M · …")
    in property <bool> pcie_active: false;
    in property <string> pcie_stats: "";
    in property <string> pcie_kinds: ""; // per-kind breakdown ("cfg 64 · mmio 1.2k · dma 245")
    in property <bool> pcie_hot: false; // PCIe rate high → warn colour

    // Live MMIO/DMA snapshot toggles (drv backend only).
    in property <bool> trace_available: false;
    in-out property <bool> trace_mmio_on;
    in-out property <bool> trace_dma_on;

    // Process-memory snapshots (--mem-pid/--mem-process): show the Snapshot button + a counter.
    in property <bool> mem_active: false;
    in property <string> snap_count: "";

    // Enter pressed in the input box, with the note text.
    callback submit(string);
    // Stop button / window close.
    callback stop();
    // MMIO/DMA trace toggles flipped.
    callback trace_mmio_toggled(bool);
    callback trace_dma_toggled(bool);
    // Memory-snapshot button pressed.
    callback snapshot();

    VerticalBox {
        padding: 10px;
        spacing: 8px;

        // Header: ● REC ......... mm:ss · size
        HorizontalBox {
            spacing: 8px;
            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: root.recording ? #e01b1b : #888888;
            }
            Text {
                text: root.status;
                font-weight: 700;
                color: root.recording ? #e01b1b : #888888;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: root.elapsed;
                font-family: "monospace";
                vertical-alignment: center;
            }
            Text {
                text: "·";
                color: #888888;
                vertical-alignment: center;
            }
            Text {
                text: root.size_text;
                font-family: "monospace";
                color: root.size_warn ? #e0a020 : #999999;
                vertical-alignment: center;
            }
        }

        // Per-source rate / volume meters (aggregates only — never contents).
        Rectangle {
            visible: root.usb_active || root.pcie_active;
            background: #00000014;
            border-radius: 4px;
            VerticalBox {
                padding: 6px;
                spacing: 2px;
                HorizontalBox {
                    visible: root.usb_active;
                    spacing: 6px;
                    Text { text: "USB"; font-weight: 700; color: #6a9bd0; min-width: 40px; }
                    Text { text: root.usb_stats; font-family: "monospace"; }
                }
                Text {
                    visible: root.usb_active && root.usb_endpoints != "";
                    text: root.usb_endpoints;
                    font-family: "monospace";
                    font-size: 11px;
                    color: #888888;
                }
                HorizontalBox {
                    visible: root.pcie_active;
                    spacing: 6px;
                    Text { text: "PCIe"; font-weight: 700; color: #b58cd0; min-width: 40px; }
                    Text {
                        text: root.pcie_stats;
                        font-family: "monospace";
                        color: root.pcie_hot ? #e0a020 : #ffffff;
                    }
                }
                Text {
                    visible: root.pcie_active && root.pcie_kinds != "";
                    text: root.pcie_kinds;
                    font-family: "monospace";
                    font-size: 11px;
                    color: #888888;
                }
            }
        }

        // Consent / what-is-recorded banner (kept visible per project policy).
        Text {
            text: "Recording keyboard, mouse, screen and device traffic on this machine. Notes you type here are timestamped onto the capture for later correlation.";
            wrap: word-wrap;
            font-size: 11px;
            color: #999999;
        }

        // Scrollback log of notes already entered.
        ListView {
            vertical-stretch: 1;
            for row in root.notes: HorizontalBox {
                spacing: 8px;
                padding: 2px;
                Text {
                    text: row.time;
                    font-family: "monospace";
                    color: #66aa99;
                    min-width: 52px;
                }
                Text {
                    text: row.text;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                }
                Text {
                    text: row.pos;
                    font-family: "monospace";
                    font-size: 11px;
                    color: #888888;
                }
            }
        }

        // Note input: Enter submits and clears.
        input := LineEdit {
            placeholder-text: "type a note and press Enter…";
            accepted(text) => {
                root.submit(text);
                self.text = "";
            }
        }

        HorizontalBox {
            spacing: 12px;
            CheckBox {
                visible: root.trace_available;
                text: "trace MMIO";
                checked <=> root.trace_mmio_on;
                toggled => {
                    root.trace_mmio_toggled(self.checked);
                }
            }
            CheckBox {
                visible: root.trace_available;
                text: "trace DMA";
                checked <=> root.trace_dma_on;
                toggled => {
                    root.trace_dma_toggled(self.checked);
                }
            }
            Text {
                visible: root.mem_active;
                text: root.snap_count;
                font-size: 11px;
                color: #888888;
                vertical-alignment: center;
            }
            Button {
                visible: root.mem_active;
                text: "📸 Snapshot";
                clicked => {
                    root.snapshot();
                }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Stop recording";
                clicked => {
                    root.stop();
                }
            }
        }
    }
}
